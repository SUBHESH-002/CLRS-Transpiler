procedure MERGE_SORT(A, p, r)
if p < r
then q = (p + r) / 2
MERGE_SORT(A, p, q)
MERGE_SORT(A, q + 1, r)
MERGE(A, p, q, r)
end
end
procedure MERGE(A, p, q, r)
n1 = q - p + 1
n2 = r - q
for i = 1 to n1
L[i] = A[p + i - 1]
end
for j = 1 to n2
R[j] = A[q + j]
end
L[n1 + 1] = infinity
R[n2 + 1] = infinity
i = 1
j = 1
for k = p to r
if L[i] <= R[j]
then A[k] = L[i]
i = i + 1
else A[k] = R[j]
j = j + 1
end
end
end
